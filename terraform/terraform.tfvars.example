prefix      = "obsplat"
environment = "dev"
location    = "eastus"

# AKS sizing — tune for your workload profile
system_node_count       = 2
system_node_size        = "Standard_D2s_v5"
user_node_min           = 2
user_node_max           = 5
user_node_size          = "Standard_D4s_v5"
observability_node_min  = 1
observability_node_max  = 3
observability_node_size = "Standard_D4s_v5"

# Network ranges — change if they collide with your hub
vnet_cidr           = "10.40.0.0/16"
aks_subnet_cidr     = "10.40.0.0/22"
ingress_subnet_cidr = "10.40.4.0/24"

# Set this to an AAD group object ID that should get cluster-admin
admin_group_object_ids = []

# Log Analytics retention
log_retention_days = 30

tags = {
  project    = "cloud-observability-platform"
  owner      = "platform-eng"
  managed_by = "terraform"
  cost_code  = "platform"
  env        = "dev"
}
