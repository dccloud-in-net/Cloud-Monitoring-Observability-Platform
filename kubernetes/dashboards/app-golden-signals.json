{
  "title": "Application Golden Signals",
  "uid": "app-golden",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "tags": ["app", "slo", "observability"],
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(http_server_requests_total, service_name)",
        "includeAll": true,
        "multi": true
      }
    ]
  },
  "panels": [
    {
      "type": "stat",
      "title": "Availability (1h)",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "1 - (sum(rate(http_server_requests_total{status=~\"5..\",service_name=~\"$service\"}[1h])) / sum(rate(http_server_requests_total{service_name=~\"$service\"}[1h])))",
        "refId": "A"
      }],
      "fieldConfig": { "defaults": { "unit": "percentunit", "decimals": 4 } }
    },
    {
      "type": "stat",
      "title": "Error budget remaining (30d)",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "1 - ((sum(increase(http_server_requests_total{status=~\"5..\",service_name=~\"$service\"}[30d])) / sum(increase(http_server_requests_total{service_name=~\"$service\"}[30d]))) / 0.001)",
        "refId": "A"
      }],
      "fieldConfig": { "defaults": { "unit": "percentunit" } }
    },
    {
      "type": "timeseries",
      "title": "Requests/sec",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [{
        "expr": "sum by (service_name) (rate(http_server_requests_total{service_name=~\"$service\"}[5m]))",
        "legendFormat": "{{service_name}}",
        "refId": "A"
      }]
    },
    {
      "type": "timeseries",
      "title": "Error rate %",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [{
        "expr": "100 * sum by (service_name) (rate(http_server_requests_total{status=~\"5..\",service_name=~\"$service\"}[5m])) / sum by (service_name) (rate(http_server_requests_total{service_name=~\"$service\"}[5m]))",
        "legendFormat": "{{service_name}}",
        "refId": "A"
      }],
      "fieldConfig": { "defaults": { "unit": "percent" } }
    },
    {
      "type": "timeseries",
      "title": "Latency p50 / p95 / p99",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum by (le) (rate(http_server_request_duration_seconds_bucket{service_name=~\"$service\"}[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_request_duration_seconds_bucket{service_name=~\"$service\"}[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_server_request_duration_seconds_bucket{service_name=~\"$service\"}[5m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    }
  ]
}
