{
  "title": "AKS Cluster Overview",
  "uid": "aks-overview",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "tags": ["aks", "platform", "observability"],
  "time": { "from": "now-3h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "node",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(kube_node_info, node)",
        "includeAll": true,
        "multi": true
      }
    ]
  },
  "panels": [
    {
      "type": "stat",
      "title": "Ready nodes",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "sum(kube_node_status_condition{condition=\"Ready\",status=\"true\"})",
        "refId": "A"
      }]
    },
    {
      "type": "stat",
      "title": "Running pods",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "sum(kube_pod_status_phase{phase=\"Running\"})",
        "refId": "A"
      }]
    },
    {
      "type": "stat",
      "title": "Crash-looping pods",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "sum(rate(kube_pod_container_status_restarts_total[5m]) > 0)",
        "refId": "A"
      }]
    },
    {
      "type": "stat",
      "title": "Cluster CPU usage %",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "100 * sum(rate(container_cpu_usage_seconds_total{image!=\"\"}[5m])) / sum(kube_node_status_allocatable{resource=\"cpu\"})",
        "refId": "A"
      }]
    },
    {
      "type": "stat",
      "title": "Cluster Mem usage %",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "100 * sum(container_memory_working_set_bytes{image!=\"\"}) / sum(kube_node_status_allocatable{resource=\"memory\"})",
        "refId": "A"
      }]
    },
    {
      "type": "timeseries",
      "title": "Node CPU usage",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [{
        "expr": "sum by (node) (rate(node_cpu_seconds_total{mode!=\"idle\",node=~\"$node\"}[5m]))",
        "legendFormat": "{{node}}",
        "refId": "A"
      }]
    },
    {
      "type": "timeseries",
      "title": "Node memory usage",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [{
        "expr": "sum by (node) (node_memory_MemTotal_bytes{node=~\"$node\"} - node_memory_MemAvailable_bytes{node=~\"$node\"})",
        "legendFormat": "{{node}}",
        "refId": "A"
      }]
    },
    {
      "type": "timeseries",
      "title": "Pod restarts (rate)",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 8 },
      "targets": [{
        "expr": "sum by (namespace,pod) (rate(kube_pod_container_status_restarts_total[5m]))",
        "legendFormat": "{{namespace}}/{{pod}}",
        "refId": "A"
      }]
    }
  ]
}
